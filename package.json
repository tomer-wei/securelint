{
  "author": "Tomer Weinstock",
  "name": "eslint-plugin-securelint",
  "version": "0.1.0",
  "description": "ESLint plugin for detecting security vulnerabilities in your code",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "security",
    "sql-injection",
    "xss",
    "linter"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/eslint": "^9.6.0",
    "eslint": "^9.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
